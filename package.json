{
  "name": "tomate-mods",
  "version": "1.0.0",
  "description": "Common abstraction layer over the Modrinth and Curseforge api",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "prepare": "pnpm build",
    "dev": "unbuild --stub",
    "script": "node scripts/index.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomate0613/tomate-mods.git"
  },
  "author": "Tomate0613",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Tomate0613/tomate-mods/issues"
  },
  "homepage": "https://github.com/Tomate0613/tomate-mods#readme",
  "dependencies": {
    "@xmcl/mod-parser": "^3.4.2",
    "@xmcl/unzip": "^2.1.2",
    "axios": "^1.18.0",
    "murmur2": "^1.0.2",
    "node-fetch": "^3.3.2",
    "p-queue": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1"
  }
}
